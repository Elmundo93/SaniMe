NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://sanime:sanime@localhost:5432/sanime
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
ADMIN_JWT_SECRET=change-me-in-every-environment
ADMIN_JWT_EXPIRES_IN=8h
LOG_LEVEL=info

# Dev-only bootstrap admin account, read by src/db/seed/admin.seed.ts.
# Leave unset outside local dev/test — the seed script no-ops without both values.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# S3-compatible object storage — MinIO locally (see docker-compose.yml), real
# S3 in production (endpoint/credentials swap only, no code change).
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=sanime
STORAGE_SECRET_ACCESS_KEY=sanime-minio
STORAGE_BUCKET=sanime-documents
STORAGE_FORCE_PATH_STYLE=true

# HMAC key for OTP code storage (never persisted alongside the code hash) —
# see modules/verification/providers/dev-code-verification.provider.ts.
VERIFICATION_CODE_PEPPER=change-me-in-every-environment
