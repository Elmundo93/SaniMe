{
  "name": "sanime",
  "version": "1.0.0",
  "workspaces": [
    "packages/@sanime/*",
    "apps/*"
  ],
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "backend:dev": "npm run start:dev --workspace apps/backend",
    "backend:build": "npm run build --workspace apps/backend",
    "backend:lint": "npm run lint --workspace apps/backend",
    "backend:typecheck": "npm run typecheck --workspace apps/backend",
    "backend:test": "npm run test --workspace apps/backend",
    "backend:test:e2e": "npm run test:e2e --workspace apps/backend",
    "backend:db:generate": "npm run db:generate --workspace apps/backend",
    "backend:db:migrate": "npm run db:migrate --workspace apps/backend",
    "backend:db:seed": "npm run db:seed --workspace apps/backend"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-text-extractor": "^2.0.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.9.2"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true
  },
  "overrides": {
    "react-dom": "19.1.0",
    "rxjs": "^7.8.2"
  }
}
